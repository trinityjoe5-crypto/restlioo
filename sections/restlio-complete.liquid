<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

<div id="RestlioMaster">
    <nav class="restlio-nav">
  <div class="container">
    <div class="nav-content">
      <div class="logo">
        {% if section.settings.logo_img != blank %}
          <img src="{{ section.settings.logo_img | image_url: width: 400 }}" alt="Restlio Logo">
        {% else %}
          Rest<span>lio</span>
        {% endif %}
      </div>
      <div class="nav-cta">
        <a href="{{ section.settings.main_product.url | default: '#' }}" class="btn-small">Shop Now</a>
      </div>
    </div>
  </div>
</nav>
<style>
  .restlio-nav {
  padding: 20px 0;
  border-bottom: 1px solid var(--border);
  background: var(--navy);
  position: sticky;
  top: 0;
  z-index: 1000;
}
.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.logo {
  font-family: 'Playfair Display', serif;
  font-size: 70px;
  font-weight: 700;
  color: var(--cream);
}
.logo span { color: var(--gold); }
.logo img { height: 80px !important; width: auto !important; display: block !important; }.btn-small {
  padding: 10px 20px;
  background: var(--gold);
  color: var(--navy);
  text-decoration: none;
  border-radius: 50px;
  font-weight: 700;
  font-size: 14px;
}
  /* ── RESET & BASE ─────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:   #080c18;
    --deep:   #0d1220;
    --card:   #111827;
    --gold:   #c9a96e;
    --gold2:  #e8c98a;
    --cream:  #f5f0e8;
    --muted:  #8a90a0;
    --border: rgba(201,169,110,.18);
    --glass:  rgba(255,255,255,.04);
    --radius: 20px;
    --glow:   0 0 60px rgba(201,169,110,.12);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--navy);
    color: var(--cream);
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    line-height: 1.7;
    overflow-x: hidden;
    cursor: none;
  }

  /* ── CUSTOM CURSOR ───────────────────────────────────── */
  .cursor {
    position: fixed; top: 0; left: 0; z-index: 9999;
    pointer-events: none;
  }
  .cursor__dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--gold);
    transform: translate(-50%,-50%);
    transition: transform .1s;
  }
  .cursor__ring {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1.5px solid rgba(201,169,110,.5);
    transform: translate(-50%,-50%);
    transition: transform .18s ease, width .25s, height .25s, border-color .25s;
    margin-top: -22px; margin-left: 0px;
    position: absolute; top: 0; left: 0;
  }
  body:has(a:hover) .cursor__ring,
  body:has(button:hover) .cursor__ring {
    width: 56px; height: 56px;
    border-color: var(--gold);
  }

  /* ── NOISE OVERLAY ───────────────────────────────────── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 1;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: .028;
  }

  /* ── STARS CANVAS ────────────────────────────────────── */
  #stars { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

  /* ── UTILITY ─────────────────────────────────────────── */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 2; }
  .section   { padding: 120px 0; }

  .tag {
    display: inline-block;
    font-size: 11px; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
    color: var(--gold); border: 1px solid var(--border);
    padding: 6px 16px; border-radius: 100px;
    margin-bottom: 24px;
    background: rgba(201,169,110,.06);
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700; line-height: 1.2;
    color: var(--cream);
  }
  h2 em { font-style: italic; color: var(--gold); }

  .subtitle {
    font-size: 18px; color: var(--muted);
    max-width: 560px; margin: 16px 0 0;
  }

  /* FADE-IN ON SCROLL */
  .reveal {
    opacity: 0; transform: translateY(40px);
    transition: opacity .8s ease, transform .8s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }
  .reveal-delay-1 { transition-delay: .1s; }
  .reveal-delay-2 { transition-delay: .22s; }
  .reveal-delay-3 { transition-delay: .34s; }
  .reveal-delay-4 { transition-delay: .46s; }

  /* ── HEADER ──────────────────────────────────────────── */
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 20px 0;
    transition: background .4s, backdrop-filter .4s, border-color .4s;
  }
  header.scrolled {
    background: rgba(8,12,24,.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; font-weight: 700;
    color: var(--cream);
    letter-spacing: -.01em;
    text-decoration: none;
  }
  .logo span { color: var(--gold); }
  .header-cta {
    font-size: 13px; font-weight: 600; letter-spacing: .06em;
    padding: 10px 24px; border-radius: 100px;
    background: var(--gold); color: var(--navy);
    border: none; cursor: none;
    transition: background .25s, transform .2s;
    text-decoration: none;
  }
  .header-cta:hover { background: var(--gold2); transform: scale(1.04); }

  /* ── HERO ────────────────────────────────────────────── */
  #hero {
    min-height: 100vh;
    display: flex; align-items: center;
    position: relative;
    padding-top: 100px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 100%, rgba(201,169,110,.07) 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 80% 20%, rgba(30,50,100,.4) 0%, transparent 60%),
      radial-gradient(ellipse 100% 100% at 20% 80%, rgba(10,20,60,.5) 0%, transparent 50%),
      linear-gradient(180deg, var(--navy) 0%, #050810 100%);
  }

  .hero-moon {
    position: absolute; right: 8%; top: 15%;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #1a2540, #080c18 70%);
    box-shadow:
      0 0 0 1px rgba(201,169,110,.08),
      0 0 80px rgba(201,169,110,.06),
      inset 0 0 60px rgba(201,169,110,.04);
    animation: moonFloat 8s ease-in-out infinite;
    z-index: 1;
  }
  .hero-moon::after {
    content: '';
    position: absolute; top: 12%; left: 18%;
    width: 36%; height: 36%; border-radius: 50%;
    background: rgba(201,169,110,.05);
    filter: blur(20px);
  }
  @keyframes moonFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%       { transform: translateY(-20px) rotate(2deg); }
  }

  .hero-content { position: relative; z-index: 2; max-width: 680px; }

  .hero-eyebrow {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 28px;
  }
  .hero-line { width: 40px; height: 1px; background: var(--gold); opacity: .6; }
  .hero-eyebrow-text {
    font-size: 11px; font-weight: 600; letter-spacing: .2em; text-transform: uppercase;
    color: var(--gold);
  }

  .hero-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 900; line-height: 1.05;
    color: var(--cream);
    margin-bottom: 24px;
  }
  .hero-headline em {
    font-style: italic; color: var(--gold);
    display: block;
  }

  .hero-sub {
    font-size: 19px; color: var(--muted); line-height: 1.65;
    max-width: 520px; margin-bottom: 44px;
  }
  .hero-sub strong { color: var(--cream); font-weight: 500; }

  .hero-actions { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 15px; font-weight: 600; letter-spacing: .04em;
    padding: 18px 36px; border-radius: 100px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
    color: var(--navy); border: none; cursor: none;
    transition: transform .25s, box-shadow .25s;
    box-shadow: 0 8px 40px rgba(201,169,110,.3);
    text-decoration: none;
  }
  .btn-primary:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 16px 60px rgba(201,169,110,.4);
  }
  .btn-primary svg { transition: transform .25s; }
  .btn-primary:hover svg { transform: translateX(4px); }

  .btn-ghost {
    font-size: 14px; color: var(--muted); cursor: none;
    text-decoration: none; display: flex; align-items: center; gap: 6px;
    transition: color .2s;
    background: none; border: none;
  }
  .btn-ghost:hover { color: var(--cream); }

  .hero-trust {
    display: flex; align-items: center; gap: 20px;
    margin-top: 56px; padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,.06);
  }
  .hero-trust-avatars { display: flex; }
  .hero-trust-avatars .av {
    width: 38px; height: 38px; border-radius: 50%;
    border: 2px solid var(--navy);
    font-size: 13px; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    margin-left: -10px;
  }
  .hero-trust-avatars .av:first-child { margin-left: 0; }
  .av-1 { background: linear-gradient(135deg,#667eea,#764ba2); }
  .av-2 { background: linear-gradient(135deg,#f093fb,#f5576c); }
  .av-3 { background: linear-gradient(135deg,#4facfe,#00f2fe); }
  .av-4 { background: linear-gradient(135deg,#43e97b,#38f9d7); }
  .av-5 { background: linear-gradient(135deg,#fa709a,#fee140); }

  .hero-trust-text { font-size: 13px; color: var(--muted); line-height: 1.4; }
  .hero-trust-text strong { color: var(--cream); display: block; font-size: 14px; }

  /* WAVE ── scrolling decoration */
  .wave-divider {
    width: 100%; overflow: hidden;
    position: relative; z-index: 2;
    margin-top: -2px;
  }
  .wave-divider svg { display: block; }

  /* ── SOCIAL PROOF BAR ────────────────────────────────── */
  .proof-bar {
    background: rgba(201,169,110,.06);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
    position: relative; z-index: 2;
  }
  .proof-bar-inner {
    display: flex; align-items: center; justify-content: center;
    gap: 48px; flex-wrap: wrap;
  }
  .proof-item {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 500; color: var(--muted);
  }
  .proof-item strong { color: var(--cream); }
  .proof-icon { font-size: 18px; }

  /* ── PROBLEM ─────────────────────────────────────────── */
  #problem { position: relative; z-index: 2; }

  .problem-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2px; margin-top: 64px;
    border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--border);
  }

  .problem-card {
    background: var(--glass);
    backdrop-filter: blur(10px);
    padding: 44px 36px;
    position: relative; overflow: hidden;
    transition: background .3s;
  }
  .problem-card:hover { background: rgba(255,255,255,.065); }
  .problem-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201,169,110,.3), transparent);
  }

  .problem-number {
    font-family: 'Playfair Display', serif;
    font-size: 4rem; font-weight: 900;
    color: rgba(201,169,110,.1);
    line-height: 1; margin-bottom: 12px;
    display: block;
  }

  .problem-icon {
    font-size: 2.4rem; margin-bottom: 16px; display: block;
    filter: grayscale(20%);
  }

  .problem-title {
    font-size: 1.2rem; font-weight: 600; color: var(--cream);
    margin-bottom: 10px;
    font-family: 'Playfair Display', serif;
  }
  .problem-desc { font-size: 15px; color: var(--muted); line-height: 1.6; }

  .problem-cta-line {
    text-align: center; margin-top: 64px;
    font-size: 18px; color: var(--muted);
  }
  .problem-cta-line strong {
    color: var(--gold);
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  /* ── SOLUTION ────────────────────────────────────────── */
  #solution {
    position: relative; z-index: 2;
    background: linear-gradient(180deg, transparent 0%, rgba(201,169,110,.03) 50%, transparent 100%);
  }

  .solution-layout {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
    margin-top: 64px;
  }
  @media(max-width:768px){ .solution-layout { grid-template-columns: 1fr; gap: 48px; } }

  /* CSS PILLOW */
  .pillow-stage {
    display: flex; align-items: center; justify-content: center;
    position: relative; min-height: 420px;
  }
  .pillow-glow {
    position: absolute; inset: -40px;
    background: radial-gradient(ellipse at center, rgba(201,169,110,.08) 0%, transparent 70%);
    animation: glowPulse 4s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%,100% { opacity: .5; transform: scale(1); }
    50%      { opacity: 1; transform: scale(1.06); }
  }
  .pillow {
    position: relative; z-index: 1;
    width: 280px; height: 200px;
    border-radius: 50px;
    background: linear-gradient(145deg, #1e2d4a 0%, #152035 40%, #0e1828 100%);
    box-shadow:
      0 40px 100px rgba(0,0,0,.6),
      0 0 0 1px rgba(201,169,110,.15),
      inset 0 1px 0 rgba(255,255,255,.08),
      inset 0 -2px 10px rgba(0,0,0,.3);
    animation: pillowFloat 6s ease-in-out infinite;
    display: flex; align-items: center; justify-content: center;
  }
  @keyframes pillowFloat {
    0%,100% { transform: translateY(0) rotate(-1deg); }
    50%      { transform: translateY(-16px) rotate(1deg); }
  }
  .pillow::before {
    content: '';
    position: absolute; inset: 12px;
    border-radius: 40px;
    border: 1px solid rgba(201,169,110,.12);
  }
  .pillow::after {
    content: '';
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 60%; height: 60%;
    border-radius: 30px;
    background: linear-gradient(135deg, rgba(201,169,110,.06), transparent);
  }
  .pillow-label {
    position: absolute; z-index: 2;
    font-family: 'Playfair Display', serif;
    font-size: .85rem; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--gold); opacity: .7;
  }
  .pillow-badge {
    position: absolute; top: -20px; right: -20px; z-index: 3;
    width: 80px; height: 80px; border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    font-size: 9px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: var(--navy);
    box-shadow: 0 8px 30px rgba(201,169,110,.4);
    animation: badgeSpin 20s linear infinite;
  }
  @keyframes badgeSpin { to { transform: rotate(360deg); } }
  .pillow-badge span { animation: badgeSpin 20s linear infinite reverse; }

  .pillow-tags {
    position: absolute;
    display: flex; flex-direction: column; gap: 10px;
  }
  .pillow-tags.left  { left: -120px; }
  .pillow-tags.right { right: -120px; text-align: right; }
  .ptag {
    font-size: 12px; font-weight: 500; color: var(--muted);
    display: flex; align-items: center; gap: 6px;
    white-space: nowrap;
  }
  .ptag .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }

  @media(max-width:900px) { .pillow-tags { display: none; } }

  .solution-points { display: flex; flex-direction: column; gap: 28px; }
  .solution-point {
    display: flex; gap: 20px; align-items: flex-start;
    padding: 24px; border-radius: 16px;
    border: 1px solid transparent;
    transition: border-color .3s, background .3s;
  }
  .solution-point:hover {
    border-color: var(--border);
    background: var(--glass);
  }
  .sp-icon {
    width: 48px; height: 48px; flex-shrink: 0;
    border-radius: 14px;
    background: rgba(201,169,110,.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    border: 1px solid rgba(201,169,110,.15);
  }
  .sp-title { font-size: 1rem; font-weight: 600; color: var(--cream); margin-bottom: 4px; }
  .sp-desc  { font-size: 14px; color: var(--muted); }

  /* ── SCIENCE BAR ─────────────────────────────────────── */
  .science-bar {
    background: rgba(201,169,110,.06);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px 40px;
    margin-top: 80px;
    display: flex; align-items: center; gap: 32px;
    position: relative; z-index: 2;
  }
  .science-icon { font-size: 3rem; flex-shrink: 0; }
  .science-text { font-size: 15px; color: var(--muted); line-height: 1.6; }
  .science-text strong { color: var(--cream); display: block; font-size: 17px; margin-bottom: 6px; }
  @media(max-width:600px) { .science-bar { flex-direction: column; padding: 24px; } }

  /* ── BENEFITS ────────────────────────────────────────── */
  #benefits { position: relative; z-index: 2; }

  .benefits-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr));
    gap: 20px; margin-top: 64px;
  }
  .benefit-card {
    background: var(--glass);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 36px 28px;
    position: relative; overflow: hidden;
    transition: transform .3s, border-color .3s, box-shadow .3s;
  }
  .benefit-card:hover {
    transform: translateY(-6px);
    border-color: rgba(201,169,110,.35);
    box-shadow: 0 24px 60px rgba(0,0,0,.4), 0 0 0 1px rgba(201,169,110,.1);
  }
  .benefit-card::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity .3s;
  }
  .benefit-card:hover::after { opacity: 1; }

  .benefit-emoji { font-size: 2.4rem; display: block; margin-bottom: 16px; }
  .benefit-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem; font-weight: 700;
    color: var(--cream); margin-bottom: 8px;
  }
  .benefit-desc { font-size: 14px; color: var(--muted); line-height: 1.6; }

  /* ── REVIEWS ─────────────────────────────────────────── */
  #reviews { position: relative; z-index: 2; }

  .reviews-header { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 20px; }
  .rating-big { display: flex; align-items: center; gap: 16px; }
  .rating-number {
    font-family: 'Playfair Display', serif;
    font-size: 4rem; font-weight: 900; color: var(--cream); line-height: 1;
  }
  .rating-details { display: flex; flex-direction: column; gap: 4px; }
  .stars-row { display: flex; gap: 3px; }
  .star { color: var(--gold); font-size: 18px; }
  .rating-count { font-size: 13px; color: var(--muted); }

  .reviews-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px,1fr));
    gap: 20px; margin-top: 48px;
  }
  .review-card {
    background: var(--glass);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    transition: transform .3s, border-color .3s;
    position: relative;
  }
  .review-card:hover {
    transform: translateY(-4px);
    border-color: rgba(201,169,110,.3);
  }
  .review-quote {
    font-size: 2.5rem; line-height: 1; color: var(--gold);
    font-family: 'Playfair Display', serif;
    opacity: .5; margin-bottom: 12px;
  }
  .review-text {
    font-size: 15px; color: var(--cream); line-height: 1.7;
    font-style: italic; margin-bottom: 24px;
  }
  .review-footer { display: flex; align-items: center; gap: 12px; }
  .review-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    font-size: 12px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    color: white; flex-shrink: 0;
  }
  .review-name { font-size: 14px; font-weight: 600; color: var(--cream); }
  .review-meta { font-size: 12px; color: var(--muted); }
  .review-stars { display: flex; gap: 2px; margin-bottom: 4px; }
  .review-star { color: var(--gold); font-size: 12px; }

  .review-verified {
    position: absolute; top: 20px; right: 20px;
    font-size: 11px; font-weight: 600; letter-spacing: .06em;
    color: #4ade80; background: rgba(74,222,128,.1);
    border: 1px solid rgba(74,222,128,.2);
    padding: 3px 10px; border-radius: 100px;
  }

  /* ── HOW IT WORKS ────────────────────────────────────── */
