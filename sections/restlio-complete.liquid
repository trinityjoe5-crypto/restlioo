  }

  .steps::before {
    content: '';
    position: absolute; top: 52px; left: calc(33% - 0px); right: calc(33% - 0px);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), var(--gold), var(--border), transparent);
  }
  @media(max-width:680px){ .steps::before { display: none; } }

  .step {
    text-align: center; padding: 0 32px;
    position: relative;
  }
  .step-num {
    width: 104px; height: 104px; border-radius: 50%;
